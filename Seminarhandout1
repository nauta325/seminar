<script>
const SURVEY_ITEMS = [
  { id: 'c', emoji: '💰', title: '수강료 미납 알림', desc: '납부 기한이 지난 학부모에게 자동으로 안내 문자 발송' },
  { id: 'd', emoji: '🚫', title: '결석/지각 자동 알림', desc: '학생이 결석하면 학부모에게 바로 문자 발송' },
  { id: 'e', emoji: '📝', title: '숙제 체크 & 미제출 알림', desc: '숙제 안 해온 학생 기록하고 학부모 알림' },
  { id: 'f', emoji: '📊', title: '월간 학습 리포트', desc: '한 달 수업 내용을 자동으로 정리해서 학부모에게 발송' },
  { id: 'g', emoji: '🎯', title: '레벨테스트 결과 관리', desc: '레벨테스트 점수 기록하고 반 배치 자동화' },
  { id: 'h', emoji: '💬', title: '상담 일지 & 예약 관리', desc: '학부모 상담 내용 기록하고 다음 상담 일정 자동 알림' },
  { id: 'i', emoji: '🖥️', title: '출결관리 + 선생님 대시보드 웹앱', desc: '노션 한계를 넘어서 — 실시간 출결, 시간표, 선생님별 대시보드를 웹앱으로 만들기' },
];

let selected = new Set();

function buildSurvey() {
  const container = document.getElementById('surveyItems');
  SURVEY_ITEMS.forEach(item => {
    const el = document.createElement('div');
    el.id = 'si-' + item.id;
    el.style.cssText = 'background:#1a1a1a;border:1.5px solid #2e2e2e;border-radius:12px;padding:16px;margin-bottom:10px;cursor:pointer;transition:all 0.2s;display:flex;align-items:flex-start;gap:14px;';
    el.innerHTML = `
      <div style="font-size:24px;flex-shrink:0;margin-top:2px">${item.emoji}</div>
      <div style="flex:1">
        <div style="font-size:15px;font-weight:800;color:#f0ece6;margin-bottom:4px">${item.title}</div>
        <div style="font-size:13px;color:#888;line-height:1.6">${item.desc}</div>
      </div>
      <div id="check-${item.id}" style="width:24px;height:24px;border-radius:7px;border:2px solid #444;flex-shrink:0;margin-top:2px;display:flex;align-items:center;justify-content:center;transition:all 0.2s;"></div>
    `;
    el.onclick = () => toggleSurveyItem(item.id, el);
    container.appendChild(el);
  });
}

function toggleSurveyItem(id, el) {
  const check = document.getElementById('check-' + id);
  if (selected.has(id)) {
    selected.delete(id);
    el.style.borderColor = '#2e2e2e';
    el.style.background = '#1a1a1a';
    check.style.background = 'transparent';
    check.style.borderColor = '#444';
    check.innerHTML = '';
  } else {
    selected.add(id);
    el.style.borderColor = '#52b788';
    el.style.background = 'rgba(82,183,136,0.08)';
    check.style.background = '#52b788';
    check.style.borderColor = '#52b788';
    check.innerHTML = '<svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M2 7L5.5 10.5L12 3" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
  }
  document.getElementById('surveySubmit').style.display = selected.size > 0 ? 'block' : 'none';
}

function submitSurvey() {
  const names = [...selected].map(id => SURVEY_ITEMS.find(i => i.id === id).title);
  document.getElementById('surveyResult').style.display = 'block';
  document.getElementById('surveyResultText').textContent = '선택하신 항목: ' + names.join(', ');
  document.getElementById('surveySubmit').style.display = 'none';
  document.getElementById('surveyResult').scrollIntoView({behavior:'smooth', block:'center'});
}

buildSurvey();
</script>

